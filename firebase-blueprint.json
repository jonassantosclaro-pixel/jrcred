{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account schema containing roles, approvals, and commission tracking for clients, colaboradores, and admins",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique user ID matching Auth user ID"
        },
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "name": {
          "type": "string",
          "description": "User full name"
        },
        "role": {
          "type": "string",
          "enum": ["client", "colaborador", "admin"],
          "description": "User hierarchy role"
        },
        "phone": {
          "type": "string",
          "description": "User contact phone number"
        },
        "approved": {
          "type": "boolean",
          "description": "Indicates if colaborador has been approved by admin"
        },
        "commissionRate": {
          "type": "number",
          "description": "Comission percentage rate for the colaborador"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp of profile creation"
        }
      },
      "required": ["uid", "email", "name", "role", "createdAt"]
    },
    "Simulation": {
      "title": "Simulation",
      "description": "Simulation data generated by either pubic visitors or authenticated agents",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Simulation unique identifier"
        },
        "clientName": {
          "type": "string",
          "description": "Client full name"
        },
        "cpf": {
          "type": "string",
          "description": "CPF number"
        },
        "phone": {
          "type": "string",
          "description": "Client contact phone number"
        },
        "nis": {
          "type": "string",
          "description": "Bolsa Familia NIS (optional)"
        },
        "benefitAmount": {
          "type": "number",
          "description": "Monthly benefit amount"
        },
        "marginRate": {
          "type": "number",
          "description": "Margin rate applied"
        },
        "marginAmount": {
          "type": "number",
          "description": "Calculated margin amount"
        },
        "installmentAmount": {
          "type": "number",
          "description": "Individual monthly installment amount"
        },
        "requestedAmount": {
          "type": "number",
          "description": "Estimated loan amount to be payout/released"
        },
        "interestRate": {
          "type": "number",
          "description": "Monthly interest rate"
        },
        "installmentsCount": {
          "type": "number",
          "description": "Total number of repayment installments"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "pre_approved", "approved", "rejected", "contracted"],
          "description": "Current simulation lifecycle status"
        },
        "type": {
          "type": "string",
          "enum": ["bolsa_familia", "inss", "fgts", "consignado_privado"],
          "description": "Underlying benefit type simulated"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp of simulation creation"
        },
        "createdBy": {
          "type": "string",
          "description": "Admin/Colaborador ID or 'public'"
        },
        "createdByName": {
          "type": "string",
          "description": "Name of the creator (e.g., Colaborador or Guest)"
        },
        "observations": {
          "type": "string",
          "description": "Internal work notes/observations for this simulation"
        }
      },
      "required": ["id", "clientName", "cpf", "phone", "benefitAmount", "marginRate", "marginAmount", "installmentAmount", "requestedAmount", "interestRate", "installmentsCount", "status", "type", "createdAt", "createdBy"]
    },
    "SystemConfig": {
      "title": "SystemConfig",
      "description": "Global settings for simulator limits, interest rates, and contact numbers",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Identifier (should be 'system_config')"
        },
        "bolsaMaxMargin": {
          "type": "number",
          "description": "Bolsa Familia maximum margin rate (e.g. 35)"
        },
        "bolsaInterestRate": {
          "type": "number",
          "description": "Bolsa Familia monthly interest rate"
        },
        "inssMaxMargin": {
          "type": "number",
          "description": "INSS maximum margin rate"
        },
        "inssInterestRate": {
          "type": "number",
          "description": "INSS monthly interest rate"
        },
        "fgtsInterestRate": {
          "type": "number",
          "description": "FGTS monthly interest rate"
        },
        "whatsappNumber": {
          "type": "string",
          "description": "JR Credito contact whatsapp phone number"
        }
      },
      "required": ["id", "bolsaMaxMargin", "bolsaInterestRate", "inssMaxMargin", "inssInterestRate", "fgtsInterestRate", "whatsappNumber"]
    }
  },
  "firestore": {
    "/configs/system_config": {
      "schema": "SystemConfig",
      "description": "Global centralized settings"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Registered app users"
    },
    "/simulations/{simulationId}": {
      "schema": "Simulation",
      "description": "All client simulations, accessible for lookup or management"
    }
  }
}
